enum VerificationStatus {
  unverified
  pending
  legally_verified
  fully_accredited
}

enum SchoolType {
  nursery
  primary
  secondary
  K12
}

enum Curriculum {
  nigerian
  british
  montessori
  other
}

enum GradingSystem {
  percentage
  waec
  gpa
  other
}

enum OwnershipType {
  private
  mission
  public
}

model Term {
  id                String           @id @default(uuid())
  identifier        String //eg. First Term
  academicSession   AcademicSession? @relation(fields: [academicSessionId], references: [id])
  academicSessionId String?
  school            School?          @relation(fields: [schoolId], references: [id])
  schoolId          String?

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  numberOfWeeks Int @map("number_of_weeks")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([academicSessionId, identifier])
  @@index([schoolId])
  @@index([academicSessionId])
  @@map("terms")
}

model AcademicSession {
  id         String  @id @default(uuid())
  identifier String // e.g. "2025/2026"
  schoolId   String?
  school     School? @relation(fields: [schoolId], references: [id])

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  terms Term[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([schoolId, identifier])
  @@index([schoolId])
  @@map("academic_sessions")
}

model School {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  academic_sessions AcademicSession[]
  terms             Term[]

  currentTermId    String?
  currentSessionId String?

  teachers Teacher[]
  staff    Staff[]
  classes  Class[]
  arms     Arm[]
  students Student[]
  subjects Subject[]

  name      String  @unique
  shortname String? @unique @map("short_name")
  address   String
  state     String
  lga       String?
  phone     String
  email     String  @unique

  type          SchoolType?
  curriculum    Curriculum?
  gradingSystem GradingSystem? @map("grading_system")

  ownershipType OwnershipType? @map("ownership_type")
  proprietor    String?

  website         String?
  logo            String?
  motto           String?
  dateOfInception DateTime? @map("date_of_inception")

  cacNumber         String? @map("cac_number")
  cacCertificateUrl String? @map("cac_certificate_url")
  moeNumber         String? @map("moe_number")
  moeCerticateUrl   String? @map("moe_certificate_url")
  trcnUrl           String? @map("trcn_url")
  tin               String? @map("tin")

  bankName      String?
  accountNumber String?
  accountName   String?

  verificationStatus VerificationStatus @default(unverified) @map("verification_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@index([state])
  @@index([lga])
  @@index([verificationStatus])
  @@map("schools")
}
