model User {
  id         String   @id @default(uuid())
  email      String?  @unique
  firstName  String   @map("first_name")
  middleName String?  @map("middle_name")
  lastName   String   @map("last_name")
  phone      String?  @unique
  role       Role     @default(ADMIN)
  password   String
  hashedRt   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  school     School?

  teacher Teacher?
  student Student?

  @@index([role])
  @@map("users")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}
