model School {
  id                String    @id @default(uuid())
  user_id           String    @unique
  user              User      @relation(fields: [user_id], references: [id])
  name              String    @unique
  address           String
  phone             String
  email             String    @unique
  website           String?
  logo              String?
  principal         String?
  description       String?
  date_of_inception DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
