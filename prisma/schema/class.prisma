enum Category {
  EARLY_YEARS
  BASIC
  JUNIOR_SECONDARY
  SENIOR_SECONDARY
  OTHER
}

model Class {
  id       String    @id @default(uuid())
  name     String
  schoolId String    @map("school_id")
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  arms     Arm[]
  students Student[]
  order    Int?
  category Category

  subjects Subject[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, schoolId])
  @@index([schoolId])
  @@index([order])
  @@index([category])
  @@map("classes")
}

model Arm {
  id   String @id @default(uuid())
  name String

  classId String @map("class_id")
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  schoolId String @map("school_id")
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classMasterId String? @map("class_master_id")
  classMaster   Staff?  @relation("ClassMaster", fields: [classMasterId], references: [id], onDelete: SetNull)

  capacity Int?
  students Student[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([classId])
  @@index([schoolId])
  @@index([classMasterId])
  @@map("arms")
}
