enum VerificationStatus {
  unverified
  pending
  legally_verified
  fully_accredited
}

enum SchoolType {
  nursery
  primary
  secondary
  K12
}

enum Curriculum {
  nigerian
  british
  montessori
  other
}

enum Term {
  first_term
  second_term
  third_term
}

enum GradingSystem {
  percentage
  waec
  gpa
  other
}

enum OwnershipType {
  private
  mission
  public
}

model School {
  id       String    @id @default(uuid())
  userId   String    @unique @map("user_id")
  user     User      @relation(fields: [userId], references: [id])
  teachers Teacher[]
  classes  Class[]
  arms     Arm[]
  students Student[]
  subjects Subject[]

  name      String  @unique
  shortname String? @unique @map("short_name")
  address   String
  state     String
  lga       String?
  phone     String
  email     String  @unique

  type           SchoolType?
  curriculum     Curriculum?
  gradingSystem  GradingSystem? @map("grading_system")
  currentTerm    Term?          @map("current_term")
  currentSession String?        @map("current_session")
  ownershipType  OwnershipType? @map("ownership_type")
  proprietor     String?

  website         String?
  logo            String?
  motto           String?
  dateOfInception DateTime? @map("date_of_inception")

  cacNumber         String? @map("cac_number")
  cacCertificateUrl String? @map("cac_certificate_url")
  moeNumber         String? @map("moe_number")
  moeCerticateUrl   String? @map("moe_certificate_url")
  trcnUrl           String? @map("trcn_url")
  tin               String? @map("tin")

  bankName      String?
  accountNumber String?
  accountName   String?

  verificationStatus VerificationStatus @default(unverified) @map("verification_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@index([state])
  @@index([lga])
  @@index([verificationStatus])
  @@map("schools")
}
