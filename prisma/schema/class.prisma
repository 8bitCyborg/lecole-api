enum Category {
  EARLY_YEARS
  BASIC
  JUNIOR_SECONDARY
  SENIOR_SECONDARY
  OTHER
}

model Class {
  id       String    @id @default(uuid())
  name     String
  schoolId String
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  arms     Arm[]
  students Student[]
  order    Int?
  category Category

  subjects Subject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
  @@index([schoolId])
  @@index([order])
  @@index([category])
}

model Arm {
  id            String    @id @default(uuid())
  name          String
  classId       String
  class         Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classMasterId String?   @unique
  classMaster   Teacher?  @relation("ClassMaster", fields: [classMasterId], references: [id], onDelete: SetNull)
  capacity      Int?
  students      Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId])
  @@index([schoolId])
}
