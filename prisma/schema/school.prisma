enum VerificationStatus {
  unverified
  pending
  legally_verified
  fully_accredited
}

enum SchoolType {
  nursery
  primary
  secondary
  K12
}

enum Curriculum {
  nigerian
  british
  montessori
  other
}

enum Term {
  first_term
  second_term
  third_term
}

enum GradingSystem {
  percentage
  waec
  gpa
  other
}

enum OwnershipType {
  private
  mission
  public
}

model School {
  id       String    @id @default(uuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id])
  teachers Teacher[]
  classes  Class[]
  arms     Arm[]
  students Student[]
  subjects Subject[]

  name      String  @unique
  shortname String? @unique
  address   String
  state     String
  lga       String?
  phone     String
  email     String  @unique

  type            SchoolType?
  curriculum      Curriculum?
  grading_system  GradingSystem?
  current_term    Term?
  current_session String?
  ownership_type  OwnershipType?
  proprietor      String?

  website           String?
  logo              String?
  motto             String?
  date_of_inception DateTime?

  cac_number          String?
  cac_certificate_url String?
  moe_number          String?
  moe_certicate_url   String?
  trcn_url            String?
  tin                 String?

  bank_name      String?
  account_number String?
  account_name   String?

  verificationStatus VerificationStatus @default(unverified)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([state])
  @@index([lga])
  @@index([verificationStatus])
  @@map("schools")
}
