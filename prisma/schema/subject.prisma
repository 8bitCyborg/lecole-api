model Subject {
  id   String  @id @default(uuid())
  name String
  code String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  classes  Class[]
  teachers Teacher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
  @@index([schoolId])
}
