enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
}

model Student {
  id       String  @id @default(uuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId String? @map("school_id")
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  classId String? @map("class_id")
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  armId String? @map("string_id")
  arm   Arm?    @relation(fields: [armId], references: [id], onDelete: SetNull)

  admissionNumber String    @unique @map("admission_number")
  dateOfBirth     DateTime? @map("date_of_birth")
  guardianPhone   String?   @map("guardian_phone")
  guardianEmail   String?   @map("guardia_email")
  isFeesPaid      Boolean   @default(false) @map("is_fees_paid")

  gender Gender
  status StudentStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([schoolId])
  @@index([classId])
  @@index([armId])
  @@index([admissionNumber])
  @@map("students")
}
